# StructIQ API keys (optional in mock mode)
KIMI_API_KEY=
ANTHROPIC_API_KEY=

# Optional runtime configuration for StructIQ backend

STRUCTIQ_STORAGE_ROOT=./backend/storage
STRUCTIQ_UPLOADS_DIR=./backend/storage/uploads
STRUCTIQ_PROCESSING_DIR=./backend/storage/processing
STRUCTIQ_RESULTS_DIR=./backend/storage/results
STRUCTIQ_FRAMES_DIR=./backend/storage/frames
STRUCTIQ_MODELS_DIR=./frontend/public/models

# Comma-separated list
STRUCTIQ_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
