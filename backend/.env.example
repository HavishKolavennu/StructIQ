# API keys
KIMI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model selection
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k-vision-preview
CLAUDE_VISION_MODEL=claude-sonnet-4-6

# Storage paths
UPLOAD_DIR=backend/uploads
PROCESSING_DIR=backend/processing
RESULTS_DIR=backend/results
MODEL_PATH=backend/models/reference.glb

# Feature flags
USE_MOCK_PIPELINE=true
USE_MOCK_CHAT=true
USE_CLAUDE_FALLBACK=true
